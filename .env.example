APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
KNOWLEDGE_INDEX_PATH=data/index/knowledge.db

# The browser talks to the frontend origin. Vite proxies /api and /ws to backend:8000.
FRONTEND_PUBLIC_HTTP_ORIGIN=http://localhost:5173
FRONTEND_PUBLIC_WS_ORIGIN=ws://localhost:5173

STT_PROVIDER=whispercpp
WHISPERCPP_BASE_URL=http://whispercpp:8080
WHISPERCPP_HOST_PORT=8081
WHISPER_CPP_VERSION=v1.8.5
WHISPERCPP_MODEL=small
WHISPERCPP_LANGUAGE=auto
WHISPERCPP_THREADS=6
WHISPERCPP_STEP_MS=3000
WHISPERCPP_WINDOW_MS=12000
WHISPERCPP_OVERLAP_MS=1000
WHISPERCPP_MINIMUM_AUDIO_MS=500
WHISPERCPP_TIMEOUT_SECONDS=120
WHISPERCPP_USE_GPU=true
WHISPERCPP_FLASH_ATTENTION=true
CUDA_VERSION=12.8.1

LLM_PROVIDER=openrouter
LLM_MODEL=~google/gemini-flash-latest
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1200

EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
LOCAL_EMBEDDING_DIMENSIONS=256

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE="Interview Helper"
