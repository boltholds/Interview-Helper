APP_ENV=development
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
KNOWLEDGE_INDEX_PATH=data/index/knowledge.db

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

STT_PROVIDER=whispercpp
WHISPERCPP_BINARY_PATH=/opt/whispercpp/bin/whisper-cli
WHISPERCPP_MODEL_PATH=/opt/whispercpp/models/ggml-small.bin
WHISPERCPP_LANGUAGE=auto
WHISPERCPP_THREADS=6
WHISPERCPP_STEP_MS=3000
WHISPERCPP_WINDOW_MS=12000
WHISPERCPP_OVERLAP_MS=1000
WHISPERCPP_MINIMUM_AUDIO_MS=500
WHISPERCPP_TIMEOUT_SECONDS=120
WHISPERCPP_USE_GPU=true
WHISPERCPP_FLASH_ATTENTION=true

LLM_PROVIDER=stub
EMBEDDING_PROVIDER=local-hash
EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_DIMENSIONS=256
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
